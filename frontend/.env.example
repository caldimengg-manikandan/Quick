VITE_API_BASE_URL=http://localhost:8000/api

# Google Maps Geocoding API key (for reverse geocoding lat/lng → address)
# Get your key at: https://console.cloud.google.com/apis/credentials
# Enable "Geocoding API" in your Google Cloud project.
# If this is left blank, the app falls back to Nominatim (OpenStreetMap) – free but less accurate.
VITE_GOOGLE_MAPS_API_KEY=
